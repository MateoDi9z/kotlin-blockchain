@startuml

skinparam classAttributeIconSize 0

package api.dtos {
    class Transaction << (D, orchid) data >> {
        + from: String
        + to: String
        + amount: Long
        + signature: String
    }
}

package dtos {
    class BlockDTO << (D, orchid) data >> {
        + index: Int
        + timestamp: Long
        + transactions: List<Transaction>
        + previousHash: String
        + hash: String
        + nonce: Long
    }
}

package api.entities.hash {
    object Hash {
        + sha256(input: String): String
    }
}

package api.entities {
    class SignatureCreator << (F, LightBlue) file >> {
        + createSignature(privateKey: PrivateKey, message: String): String
        + verifySignature(publicKey: PublicKey?, message: String, signature: String): Boolean
        + getPublicKeyFromString(keyString: String): PublicKey?
    }
}

package entities.block {
    class Block {
        + index: Int
        + timestamp: Long
        + transactions: List<Transaction>
        + previousHash: String
        + hash: String
        + nonce: Long
        + calculateHash(nonceToUse: Long): String
        + mineBlock(difficulty: Int): Block
        + isValid(difficulty: Int): Boolean
    }

    object BlockValidator {
        + validateReceivedBlock(dto: BlockDTO, difficulty: Int, previousBlock: Block, txValidator: TransactionValidator): Boolean
        - mapToEntity(dto: BlockDTO): Block
        - verifyTransactions(block: Block, validator: TransactionValidator): Boolean
    }
}

package entities.block.rule {
    interface BlockRule {
        + isValid(block: Block, difficulty: Int, previousBlock: Block): Boolean
        + getErrorMessage(): String
    }

    class CompositeBlockRule {
        - rules: List<BlockRule>
        - lastError: String
        + isValid(block: Block, difficulty: Int, previousBlock: Block): Boolean
        + getErrorMessage(): String
    }

    class ChainLinkRule {
        + isValid(block: Block, difficulty: Int, previousBlock: Block): Boolean
        + getErrorMessage(): String
    }

    class BlockIntegrityRule {
        + isValid(block: Block, difficulty: Int, previousBlock: Block): Boolean
        + getErrorMessage(): String
    }
}

package api.entities.transaction.rules {
    interface TransactionRule {
        + isValid(transaction: Transaction): Boolean
        + getErrorMessage(): String
    }

    class PositiveAmountRule {
        + isValid(transaction: Transaction): Boolean
        + getErrorMessage(): String
    }

    class ValidCryptographicSignatureRule {
        + isValid(transaction: Transaction): Boolean
        + getErrorMessage(): String
    }

    class SignatureNotEmptyRule {
        + isValid(transaction: Transaction): Boolean
        + getErrorMessage(): String
    }
}

package entities.transaction.rules {
    class ValidationResult << (D, orchid) data >> {
        + isValid: Boolean
        + errorList: List<String>
        + getErrors(): String
    }
}

package entities.transaction.validator {
    class TransactionValidator {
        - rules: List<TransactionRule>
        + validate(transaction: Transaction): ValidationResult
    }
}

package entities.blockchain {
    class Blockchain {
        + difficulty: Int
        - validator: TransactionValidator
        - _chain: MutableList<Block>
        + chain: List<Block>
        - _pendingTransactions: MutableList<Transaction>
        + pendingTransactions: List<Transaction>
        - createGenesisBlock(): Block
        + addTransaction(transaction: Transaction): TransactionAdditionResult
        + getLatestBlock(): Block
        + minePendingTransactions(): Block
        + isChainValid(chainToValidate: List<Block>): Boolean
        + replaceChain(newChain: List<Block>): ChainSyncResult
    }
}

package entities.blockchain.results {
    interface TransactionAdditionResult <<sealed>>

    object "Success" as TxAdditionSuccess

    class "Rejected" as TxAdditionRejected << (D, orchid) data >> {
        + errors: String
    }
}

package api.entities.blockchain.results {
    interface ChainSyncResult <<sealed>>

    object "Success" as ChainSyncSuccess

    class "Rejected" as ChainSyncRejected << (D, orchid) data >> {
        + reason: String
    }
}

package api.services {
    class ExampleService
}

package api.controllers {
    class ExampleController
}

package api.repositories {
    class ExampleRepository
}

package api.routes {
    class ExampleRouter
}

package api {
    class ExampleServiceApplication

    class ApplicationRunner << (F, LightBlue) file >> {
        + main(args: Array<String>)
    }
}

' Relaciones - Reglas de Bloques
CompositeBlockRule ..|> BlockRule
ChainLinkRule ..|> BlockRule
BlockIntegrityRule ..|> BlockRule
CompositeBlockRule o-- "*" BlockRule : contains

' Relaciones - Reglas de Transacciones
PositiveAmountRule ..|> TransactionRule
ValidCryptographicSignatureRule ..|> TransactionRule
SignatureNotEmptyRule ..|> TransactionRule

TransactionValidator o-- "*" TransactionRule : contains
TransactionValidator ..> ValidationResult : returns

' Dependencias funcionales
ValidCryptographicSignatureRule ..> SignatureCreator : uses functions

' Relaciones de Results (Sealed Interfaces)
TxAdditionSuccess ..|> TransactionAdditionResult
TxAdditionRejected ..|> TransactionAdditionResult

ChainSyncSuccess ..|> ChainSyncResult
ChainSyncRejected ..|> ChainSyncResult

' Relaciones principales del core
Blockchain o-- "1" TransactionValidator
Blockchain *-- "*" Block : chain
Blockchain o-- "*" Transaction : pendingTransactions
Blockchain ..> TransactionAdditionResult : returns
Blockchain ..> ChainSyncResult : returns

Block --> "*" Transaction : contains
BlockDTO --> "*" Transaction : contains

BlockValidator ..> Block : creates/validates
BlockValidator ..> BlockDTO : maps from

@enduml