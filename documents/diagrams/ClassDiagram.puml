@startuml
skinparam classAttributeIconSize 0

class Transaction {
  + String from
  + String to
  + double amount
  + String sig
  + boolean isValid(TransactionRule validator)
}

interface TransactionRule {
  + boolean isValid(Transaction tx)
  + String getErrorMessage()
}

class CompositeTransactionRule {
  - List<TransactionRule> rules
  + boolean isValid(Transaction tx)
  + String getErrorMessage()
}

class PositiveAmountRule implements TransactionRule
class SignatureNotEmptyRule implements TransactionRule
class CryptographicSignatureRule implements TransactionRule

class Block {
  + int index
  + long timestamp
  + List<Transaction> transactions
  + String previousHash
  + String hash
  + int nonce
  + String calculateHash()
  + void mineBlock(int difficulty)
}

class Blockchain {
  - List<Block> chain
  - List<Transaction> pendingTransactions
  - TransactionRule validator
  + boolean addBlock(Block newBlock)
  + boolean createTransaction(Transaction tx)
  + void minePendingTransactions()
  + boolean resolveConflicts(List<Block> peerChain)
}

class Node {
  - String nodeId
  - List<String> peers
  - Blockchain blockchain
  + void connectToNetwork(String seedUrl)
  + void onTransactionReceived(Transaction tx)
  + void onBlockReceived(Block block)
  + void broadcastBlock(Block block)
}

' Relationships
Blockchain "1" *-- "*" Block : contains >
Blockchain "1" *-- "*" Transaction : pending transactions >
Blockchain "1" o-- "1" TransactionRule : uses for validation >
Block "1" *-- "*" Transaction : includes >
CompositeTransactionRule "1" o-- "*" TransactionRule : groups >
Node "1" --> "1" Blockchain : uses >
Node "1" o-- "*" Node : connects with >

@enduml